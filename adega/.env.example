### Example environment variables for local development
# Copy this file to `.env` and fill real secret values. Do NOT commit `.env`.

# Application token secret used to sign JWTs
API_SECURITY_TOKEN_SECRET=replace_me_with_a_long_random_string

# Database connection defaults (override if needed)
DB_HOST=localhost
DB_PORT=3307
MYSQL_DATABASE=adega_db
MYSQL_USER=adega_user
MYSQL_PASSWORD=adega_password

# Any other secrets go here
#SOME_API_KEY=your_api_key_here
